# Required: Your OpenAI API key
FORGE_AI_OPENAI_API_KEY=sk-...

# Optional: Model configuration
FORGE_AI_DEFAULT_MODEL=gpt-4o
FORGE_AI_TIMEOUT=30
FORGE_AI_MAX_TOKENS=4096

# Optional: Retry configuration
FORGE_RETRY_DEFAULT_ATTEMPTS=3
FORGE_RETRY_DEFAULT_BACKOFF=exponential
FORGE_RETRY_DEFAULT_BASE_DELAY=1.0
