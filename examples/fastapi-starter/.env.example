# Forge Configuration
FORGE_ENVIRONMENT=development
FORGE_DEBUG=true
FORGE_LOG_LEVEL=INFO
FORGE_LOG_FORMAT=dev

# Cache backend: "memory" or "redis"
FORGE_CACHE_BACKEND=memory
FORGE_CACHE_DEFAULT_TTL=300

# Redis (required when FORGE_CACHE_BACKEND=redis)
# FORGE_CACHE_REDIS_URL=redis://localhost:6379/0
